---
/**
 * ReadingPathNav — previous/next navigation for series posts.
 *
 * Props:
 *   prev         — { title, slug } | null
 *   next         — { title, slug } | null
 *   seriesTitle  — name of the series
 *   currentIndex — 1-based position in the series
 *   total        — total number of posts in the series
 */

interface NavItem {
  title: string;
  slug: string;
}

interface Props {
  prev?: NavItem | null;
  next?: NavItem | null;
  seriesTitle?: string;
  currentIndex?: number;
  total?: number;
}

const {
  prev = null,
  next = null,
  seriesTitle,
  currentIndex,
  total,
} = Astro.props;

const hasProgress = currentIndex !== undefined && total !== undefined;
const progressPct = hasProgress ? Math.round((currentIndex / total) * 100) : 0;
---

<nav
  class="mt-12 border-t border-[var(--border-subtle)] pt-10"
  aria-label="Series navigation"
>
  <!-- Series context -->
  {
    (seriesTitle || hasProgress) && (
      <div class="mb-6 flex flex-col gap-2">
        {seriesTitle && (
          <p class="text-xs font-medium uppercase tracking-wider text-[var(--text-tertiary)]">
            Part of:{" "}
            <span class="text-[var(--text-primary)]">{seriesTitle}</span>
          </p>
        )}
        {hasProgress && (
          <div class="flex items-center gap-3">
            <div
              class="h-1.5 flex-1 overflow-hidden rounded-full bg-[var(--bg-muted)]"
              role="progressbar"
              aria-valuenow={currentIndex}
              aria-valuemin={1}
              aria-valuemax={total}
              aria-label={`Post ${currentIndex} of ${total}`}
            >
              <div
                class="h-full rounded-full bg-violet-500 transition-all"
                style={`width: ${progressPct}%`}
              />
            </div>
            <span class="shrink-0 text-xs text-[var(--text-tertiary)]">
              {currentIndex} / {total}
            </span>
          </div>
        )}
      </div>
    )
  }

  <!-- Prev / Next links -->
  <div class="grid gap-4 sm:grid-cols-2">
    <!-- Previous -->
    <div>
      {
        prev ? (
          <a
            href={`/essays/${prev.slug}/`}
            class="group flex flex-col gap-1 rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-surface)] p-5 transition-all hover:border-violet-400/50 hover:shadow-sm dark:hover:border-violet-700"
          >
            <span class="flex items-center gap-1 text-xs font-medium text-[var(--text-tertiary)] group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m15 18-6-6 6-6" />
              </svg>
              Previous
            </span>
            <span class="font-medium leading-snug text-[var(--text-primary)] group-hover:text-violet-700 dark:group-hover:text-violet-300 transition-colors">
              {prev.title}
            </span>
          </a>
        ) : (
          <div class="rounded-xl border border-dashed border-[var(--border-subtle)] p-5">
            <span class="text-sm text-[var(--text-disabled)]">
              Beginning of series
            </span>
          </div>
        )
      }
    </div>

    <!-- Next -->
    <div>
      {
        next ? (
          <a
            href={`/essays/${next.slug}/`}
            class="group flex flex-col items-end gap-1 rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-surface)] p-5 text-right transition-all hover:border-violet-400/50 hover:shadow-sm dark:hover:border-violet-700"
          >
            <span class="flex items-center gap-1 text-xs font-medium text-[var(--text-tertiary)] group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
              Next
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </span>
            <span class="font-medium leading-snug text-[var(--text-primary)] group-hover:text-violet-700 dark:group-hover:text-violet-300 transition-colors">
              {next.title}
            </span>
          </a>
        ) : (
          <div class="flex h-full items-start justify-end rounded-xl border border-dashed border-[var(--border-subtle)] p-5">
            <span class="text-sm text-[var(--text-disabled)]">
              End of series
            </span>
          </div>
        )
      }
    </div>
  </div>
</nav>
