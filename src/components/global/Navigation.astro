---
import { site } from '../../data/site';
import ThemeToggle from './ThemeToggle';
import ModeToggle from './ModeToggle';
import SearchBox from './SearchBox';
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full bg-[var(--bg-surface)]/80 backdrop-blur-[20px] backdrop-saturate-150 transition-shadow"
>
  <nav
    class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8"
    aria-label="Main navigation"
  >
    <!-- Site logo / wordmark -->
    <a
      href="/"
      class="group flex items-center gap-2.5 text-[var(--text-primary)] no-underline transition-opacity hover:opacity-80"
      aria-label={site.title}
    >
      <img
        src="/assets/s2s.svg"
        alt="Signal to System Logo"
        class="h-8 w-auto object-contain origin-left scale-[1.5]"
        style="height: 32px; width: auto;"
        loading="eager"
      />
    </a>

    <!-- Desktop nav links -->
    <div class="hidden items-center gap-1 lg:flex">
      {
        site.nav.map((item) => (
          <a
            href={item.href}
            class="rounded-md px-3 py-1.5 text-sm font-medium text-[var(--text-tertiary)] transition-colors hover:bg-[var(--bg-muted)] hover:text-[var(--text-primary)]"
          >
            {item.label}
          </a>
        ))
      }
    </div>

    <!-- Right-side controls -->
    <div class="flex items-center gap-2">
      <!-- Search trigger -->
      <SearchBox client:load />

      <!-- Theme toggle -->
      <ThemeToggle client:load />

      <!-- Performance mode toggle -->
      <ModeToggle client:load />

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
        class="flex h-9 w-9 items-center justify-center rounded-md text-[var(--text-tertiary)] transition-colors hover:bg-[var(--bg-muted)] hover:text-[var(--text-primary)] lg:hidden"
      >
        <svg
          id="hamburger-icon"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg
          id="close-icon"
          class="hidden h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden bg-[var(--bg-surface)] px-4 pb-4 pt-2 lg:hidden"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="space-y-1">
      {
        site.nav.map((item) => (
          <li>
            <a
              href={item.href}
              class="block rounded-md px-3 py-2 text-sm font-medium text-[var(--text-tertiary)] transition-colors hover:bg-[var(--bg-muted)] hover:text-[var(--text-primary)]"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden', isOpen);
    hamburger?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
  });

  // Close menu when clicking a link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // Add shadow on scroll
  const header = document.getElementById('site-header');
  const observer = new IntersectionObserver(
    ([entry]) => {
      header?.classList.toggle('shadow-ambient', !entry.isIntersecting);
    },
    { rootMargin: '-1px 0px 0px 0px', threshold: 0 }
  );
  const sentinel = document.createElement('div');
  sentinel.style.height = '1px';
  document.body.prepend(sentinel);
  observer.observe(sentinel);
</script>
