---
import { site } from '../../data/site';

const year = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  GitHub: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  LinkedIn: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  'Twitter / X': `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
};
---

<footer class="dark bg-[var(--bg-subtle)] mt-24">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <!-- Top section: brand + nav + social -->
    <div class="grid grid-cols-1 gap-10 md:grid-cols-3 lg:grid-cols-4">
      <!-- Brand column -->
      <div class="lg:col-span-2">
        <a
          href="/"
          class="inline-flex items-center gap-2.5 text-[var(--text-primary)] no-underline transition-opacity hover:opacity-80"
        >
          <img
            src="/assets/s2s.svg"
            alt="Signal to System Logo"
            class="h-8 w-auto object-contain origin-left scale-[1.5]"
            style="height: 32px; width: auto;"
            loading="lazy"
          />
        </a>

        <p class="mt-3 max-w-xs text-sm leading-relaxed text-[var(--text-tertiary)]">
          {site.subtitle}
        </p>

        <!-- Social links -->
        <div class="mt-5 flex items-center gap-3">
          {
            site.footer.social.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--border-default)] text-[var(--text-tertiary)] transition-colors hover:border-[var(--border-strong)] hover:text-[var(--text-secondary)]"
                set:html={socialIcons[social.label] ?? social.label}
              />
            ))
          }

          <!-- RSS -->
          <a
            href="/rss.xml"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="RSS feed"
            class="flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--border-default)] text-[var(--text-tertiary)] transition-colors hover:border-[var(--border-strong)] hover:text-[var(--text-secondary)]"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="h-5 w-5">
              <path
                d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav links column -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--text-tertiary)]">
          Content
        </h3>
        <ul class="space-y-2.5">
          {
            site.footer.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)]"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- About column -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-[var(--text-tertiary)]">
          Author
        </h3>
        <p class="text-sm leading-relaxed text-[var(--text-secondary)]">
          {site.author.name}
        </p>
        <p class="mt-2 text-sm leading-relaxed text-[var(--text-tertiary)]">
          {site.author.bio}
        </p>
        <a
          href="/about"
          class="mt-3 inline-block text-sm text-[var(--accent)] transition-colors hover:text-[var(--accent-hover)]"
        >
          More about me &rarr;
        </a>
      </div>
    </div>

    <!-- Bottom bar: copyright + disclaimer -->
    <div class="mt-16 pt-8 space-y-3 border-t border-[var(--border-subtle)]">
      <p class="text-xs leading-relaxed text-[var(--text-disabled)]">
        {site.defaultDisclaimer}
      </p>
      <p class="text-xs text-[var(--text-disabled)]">
        &copy; {year} {site.author.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
