---
/**
 * MetadataRow — horizontal strip of post metadata with icons.
 *
 * Props:
 *   date        — publication date (ISO string or Date)
 *   readTime    — e.g. "8 min read"
 *   category    — category label string
 *   updatedDate — optional last-updated date
 */

interface Props {
  date: string | Date;
  readTime?: string;
  category?: string;
  updatedDate?: string | Date;
  class?: string;
}

const { date, readTime, category, updatedDate, class: className = "" } = Astro.props;

function formatDate(d: string | Date): string {
  const obj = typeof d === "string" ? new Date(d) : d;
  return obj.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<div
  class={`flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-zinc-500 dark:text-zinc-400 ${className}`}
>
  <!-- Date -->
  <span class="flex items-center gap-1.5">
    <!-- calendar icon (inline SVG to avoid import overhead) -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect width="18" height="18" x="3" y="4" rx="2" ry="2" />
      <line x1="16" x2="16" y1="2" y2="6" />
      <line x1="8" x2="8" y1="2" y2="6" />
      <line x1="3" x2="21" y1="10" y2="10" />
    </svg>
    <time datetime={new Date(date).toISOString()}>{formatDate(date)}</time>
  </span>

  <!-- Read time -->
  {
    readTime && (
      <span class="flex items-center gap-1.5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10" />
          <polyline points="12 6 12 12 16 14" />
        </svg>
        <span>{readTime}</span>
      </span>
    )
  }

  <!-- Category -->
  {
    category && (
      <span class="flex items-center gap-1.5">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z" />
        </svg>
        <span>{category}</span>
      </span>
    )
  }

  <!-- Updated date -->
  {
    updatedDate && (
      <span class="flex items-center gap-1.5 italic">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12a9 9 0 0 1-9 9m9-9a9 9 0 0 0-9-9m9 9H3m9 9a9 9 0 0 1-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9" />
        </svg>
        <span>Updated {formatDate(updatedDate)}</span>
      </span>
    )
  }
</div>
