---
import { formatTitle, resolveOgImage } from '../lib/seo';
import { site } from '../data/site';
import Navigation from '../components/global/Navigation.astro';
import Footer from '../components/global/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  jsonLd?: Record<string, unknown>;
  class?: string;
}

const {
  title,
  description = site.description,
  ogImage,
  canonicalUrl,
  jsonLd,
  class: className,
} = Astro.props;

const resolvedTitle = formatTitle(title);
const resolvedOgImage = resolveOgImage(ogImage);
const resolvedCanonical = canonicalUrl ?? new URL(Astro.url.pathname, site.siteUrl).href;
const resolvedDescription = description.slice(0, 160);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/brand/apple-touch-icon.png" />

    <!-- Google Fonts: Inter, Noto Serif, Space Grotesk -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Noto+Serif:ital,wght@0,100..900;1,100..900&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Primary Meta -->
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content={site.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:site" content="@nickmiethe" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.title} RSS Feed`}
      href="/rss.xml"
    />

    <!-- JSON-LD Structured Data -->
    {
      jsonLd && (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }

    <!--
      Theme initialization: runs synchronously before first paint to prevent
      flash of incorrect theme. Reads localStorage preference, falls back to
      system preference, then sets .dark class on <html>.
    -->
    <script is:inline>
      (function () {
        var stored = null;
        try { stored = localStorage.getItem('s2s-theme'); } catch (_) {}
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var isDark = stored === 'dark' || (stored === null && prefersDark);
        var html = document.documentElement;
        if (isDark) {
          html.classList.add('dark');
          html.classList.remove('light');
        } else {
          html.classList.remove('dark');
          html.classList.add('light');
        }
        // Also apply performance mode
        var perfMode = null;
        try { perfMode = localStorage.getItem('s2s-performance-mode'); } catch (_) {}
        if (perfMode === 'lite') {
          html.classList.add('perf-lite');
        }
      })();
    </script>
  </head>

  <body class="min-h-screen bg-[var(--bg-base)] text-[var(--text-primary)] antialiased transition-colors duration-200">
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Navigation slot: allows pages to pass a custom nav or use the default -->
    <slot name="nav">
      <Navigation />
    </slot>

    <main id="main-content" class:list={['', className]}>
      <slot />
    </main>

    <Footer />
  </body>
</html>
