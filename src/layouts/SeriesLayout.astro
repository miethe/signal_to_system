---
import BaseLayout from './BaseLayout.astro';
import { buildCanonicalUrl } from '../lib/seo';
import { formatDate, formatDateISO } from '../lib/utils';
import { site } from '../data/site';

interface SeriesPost {
  slug: string;
  title: string;
  excerpt?: string;
  date?: Date | string;
  readTime?: number;
  part?: number;
}

interface Props {
  frontmatter: {
    title: string;
    excerpt?: string;
    description?: string;
    date?: Date | string;
    status?: 'active' | 'planned' | 'complete';
    tags?: string[];
    ogImage?: string;
  };
  posts: SeriesPost[];
}

const { frontmatter, posts } = Astro.props;

const {
  title,
  excerpt,
  description,
  date,
  status = 'active',
  tags = [],
  ogImage,
} = frontmatter;

const pageDescription = description || excerpt || site.description;
const canonicalUrl = buildCanonicalUrl(Astro.url.pathname);

const statusConfig: Record<string, { label: string; classes: string; dot: string }> = {
  active: {
    label: 'Active Series',
    classes: 'bg-emerald-500/10 text-emerald-400 ring-1 ring-emerald-500/20',
    dot: 'bg-emerald-400',
  },
  planned: {
    label: 'Coming Soon',
    classes: 'bg-sky-500/10 text-sky-400 ring-1 ring-sky-500/20',
    dot: 'bg-sky-400',
  },
  complete: {
    label: 'Complete',
    classes: 'bg-slate-500/10 text-slate-400 ring-1 ring-slate-500/20',
    dot: 'bg-slate-400',
  },
};

const sc = statusConfig[status] || statusConfig.active;

// Sort posts by part number, then by date
const sortedPosts = [...posts].sort((a, b) => {
  if (a.part !== undefined && b.part !== undefined) return a.part - b.part;
  if (a.date && b.date) return new Date(a.date).getTime() - new Date(b.date).getTime();
  return 0;
});
---

<BaseLayout
  title={title}
  description={pageDescription}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Series header -->
    <header class="mb-12 space-y-5 border-b border-[var(--border-subtle)] pb-10">
      <div class="flex items-center gap-3">
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--text-disabled)]">
          Series
        </span>
        <span class="text-[var(--border)]">/</span>
        <span
          class:list={[
            'inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-semibold',
            sc.classes,
          ]}
        >
          <span class:list={['h-1.5 w-1.5 rounded-full', sc.dot]}></span>
          {sc.label}
        </span>
      </div>

      <h1 class="text-3xl font-bold leading-tight tracking-tight text-[var(--text-primary)] sm:text-4xl lg:text-5xl">
        {title}
      </h1>

      {
        excerpt && (
          <p class="text-lg leading-relaxed text-[var(--text-tertiary)] sm:text-xl">{excerpt}</p>
        )
      }

      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-[var(--text-disabled)]">
        {
          date && (
            <time datetime={formatDateISO(date)}>{formatDate(date)}</time>
          )
        }
        <span>{sortedPosts.length} {sortedPosts.length === 1 ? 'entry' : 'entries'}</span>
      </div>

      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 pt-1">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full bg-[var(--bg-muted)] px-3 py-0.5 text-xs font-medium text-[var(--text-tertiary)] transition-colors hover:bg-[var(--bg-surface)] hover:text-[var(--text-secondary)]"
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <!-- Series overview content (MDX body) -->
    {
      Astro.slots.has('default') && (
        <div class="prose-custom mb-12 max-w-none">
          <slot />
        </div>
      )
    }

    <!-- Ordered post list -->
    <section>
      <h2 class="mb-6 text-xs font-bold uppercase tracking-widest text-[var(--text-disabled)]">
        All Entries
      </h2>

      <ol class="space-y-4">
        {
          sortedPosts.map((post, index) => (
            <li>
              <a
                href={`/posts/${post.slug}`}
                class="group flex items-start gap-5 rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-subtle)] p-5 transition-all duration-150 hover:border-indigo-500/40 hover:bg-[var(--bg-muted)]"
              >
                <!-- Part number -->
                <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-[var(--border)] bg-[var(--bg-subtle)] text-sm font-bold text-[var(--text-disabled)] transition-colors group-hover:border-indigo-500/60 group-hover:text-[var(--accent)]">
                  {post.part ?? index + 1}
                </span>

                <!-- Content -->
                <div class="min-w-0 flex-1">
                  <h3 class="font-semibold text-[var(--text-secondary)] transition-colors group-hover:text-[var(--text-primary)]">
                    {post.title}
                  </h3>
                  {post.excerpt && (
                    <p class="mt-1 text-sm leading-relaxed text-[var(--text-disabled)]">
                      {post.excerpt}
                    </p>
                  )}
                  <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--text-disabled)]">
                    {post.date && (
                      <time datetime={formatDateISO(post.date)}>
                        {formatDate(post.date)}
                      </time>
                    )}
                    {post.readTime && (
                      <span>{post.readTime} min read</span>
                    )}
                  </div>
                </div>

                <!-- Arrow -->
                <svg
                  class="mt-0.5 h-5 w-5 shrink-0 text-[var(--border)] transition-colors group-hover:text-[var(--accent)]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </li>
          ))
        }
      </ol>
    </section>

    <!-- Back link -->
    <footer class="mt-12 border-t border-[var(--border-subtle)] pt-8">
      <a
        href="/series"
        class="text-sm text-[var(--accent)] transition-colors hover:text-[var(--accent-hover)]"
      >
        &larr; All Series
      </a>
    </footer>
  </div>
</BaseLayout>
