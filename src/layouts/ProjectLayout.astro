---
import BaseLayout from './BaseLayout.astro';
import { generateJsonLd, buildCanonicalUrl } from '../lib/seo';
import { formatDate, formatDateISO } from '../lib/utils';
import { site } from '../data/site';

interface Props {
  frontmatter: {
    title: string;
    excerpt?: string;
    description?: string;
    date: Date | string;
    type?: string;
    tags?: string[];
    ogImage?: string;
    repo?: string;
    site?: string;
    artifact?: string;
    demo?: string;
    public?: boolean;
    status?: 'active' | 'archived' | 'wip' | 'planned';
  };
}

const { frontmatter } = Astro.props;

const {
  title,
  excerpt,
  description,
  date,
  type,
  tags = [],
  ogImage,
  repo,
  site: projectSite,
  artifact,
  demo,
  public: isPublic = true,
  status = 'active',
} = frontmatter;

const pageDescription = description || excerpt || site.description;
const canonicalUrl = buildCanonicalUrl(Astro.url.pathname);
const publishedISO = formatDateISO(date);

const jsonLd = generateJsonLd('article', {
  title,
  description: pageDescription,
  url: canonicalUrl,
  image: ogImage,
  datePublished: publishedISO,
  tags,
});

const statusColors: Record<string, string> = {
  active: 'bg-emerald-500/10 text-emerald-400 ring-emerald-500/20',
  wip: 'bg-amber-500/10 text-amber-400 ring-amber-500/20',
  planned: 'bg-sky-500/10 text-sky-400 ring-sky-500/20',
  archived: 'bg-slate-500/10 text-slate-400 ring-slate-500/20',
};
const statusLabel: Record<string, string> = {
  active: 'Active',
  wip: 'In Progress',
  planned: 'Planned',
  archived: 'Archived',
};
---

<BaseLayout
  title={title}
  description={pageDescription}
  ogImage={ogImage}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-10 space-y-4 border-b border-[var(--border-subtle)] pb-8">
      <div class="flex flex-wrap items-center gap-3">
        {
          type && (
            <span class="inline-block rounded-sm bg-indigo-600/20 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-widest text-[var(--accent)] ring-1 ring-indigo-500/30">
              {type}
            </span>
          )
        }
        <span
          class:list={[
            'inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1',
            statusColors[status] || statusColors.active,
          ]}
        >
          <span
            class:list={[
              'inline-block h-1.5 w-1.5 rounded-full',
              status === 'active' ? 'bg-emerald-400' :
              status === 'wip' ? 'bg-amber-400' :
              status === 'planned' ? 'bg-sky-400' : 'bg-slate-400',
            ]}
          ></span>
          {statusLabel[status] || status}
        </span>
      </div>

      <h1 class="text-3xl font-bold leading-tight tracking-tight text-[var(--text-primary)] sm:text-4xl">
        {title}
      </h1>

      {excerpt && <p class="text-lg leading-relaxed text-[var(--text-tertiary)]">{excerpt}</p>}

      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[var(--text-disabled)]">
        <time datetime={publishedISO} class="text-[var(--text-tertiary)]">{formatDate(date)}</time>
      </div>

      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2 pt-1">
            {tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-full bg-[var(--bg-muted)] px-3 py-0.5 text-xs font-medium text-[var(--text-tertiary)] transition-colors hover:bg-[var(--bg-surface)] hover:text-[var(--text-secondary)]"
              >
                #{tag}
              </a>
            ))}
          </div>
        )
      }

      <!-- External links row -->
      <div class="flex flex-wrap items-center gap-3 pt-2">
        {
          repo && (
            <a
              href={repo}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg-subtle)] px-4 py-2 text-sm font-medium text-[var(--text-secondary)] transition-colors hover:border-[var(--border-subtle)] hover:text-[var(--text-primary)]"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
              </svg>
              Repository
            </a>
          )
        }
        {
          projectSite && (
            <a
              href={projectSite}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-[var(--border)] bg-[var(--bg-subtle)] px-4 py-2 text-sm font-medium text-[var(--text-secondary)] transition-colors hover:border-[var(--border-subtle)] hover:text-[var(--text-primary)]"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              Live Site
            </a>
          )
        }
        {
          artifact && (
            <a
              href={artifact}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-indigo-700/50 bg-indigo-600/10 px-4 py-2 text-sm font-medium text-[var(--accent)] transition-colors hover:border-indigo-600 hover:text-[var(--accent-hover)]"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download Artifact
            </a>
          )
        }
      </div>
    </header>

    <!-- Demo / artifact region -->
    {
      demo && isPublic && (
        <div class="mb-10 overflow-hidden rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-subtle)]">
          <div class="flex items-center gap-2 border-b border-[var(--border-subtle)] bg-[var(--bg-subtle)] px-4 py-2.5">
            <div class="flex gap-1.5">
              <span class="h-3 w-3 rounded-full bg-[var(--bg-muted)]"></span>
              <span class="h-3 w-3 rounded-full bg-[var(--bg-muted)]"></span>
              <span class="h-3 w-3 rounded-full bg-[var(--bg-muted)]"></span>
            </div>
            <span class="ml-2 text-xs text-[var(--text-disabled)]">Demo</span>
          </div>
          <iframe
            src={demo}
            class="h-96 w-full border-0"
            title={`${title} demo`}
            loading="lazy"
          />
        </div>
      )
    }

    <!-- Non-public notice -->
    {
      !isPublic && (
        <aside class="mb-8 rounded-lg border border-[var(--border)] bg-[var(--bg-subtle)] p-5 text-center">
          <p class="text-sm text-[var(--text-tertiary)]">
            This project is not publicly available. Summary and context are provided below.
          </p>
        </aside>
      )
    }

    <!-- Body content -->
    <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-[var(--text-primary)] prose-p:text-[var(--text-secondary)] prose-p:leading-relaxed prose-a:text-[var(--accent)] prose-a:no-underline hover:prose-a:text-[var(--accent-hover)] hover:prose-a:underline prose-strong:text-[var(--text-primary)] prose-code:rounded prose-code:bg-[var(--code-bg)] prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:text-[var(--code-text)] prose-pre:border prose-pre:border-[var(--code-border)] prose-pre:bg-[var(--code-bg-block)] prose-blockquote:border-l-[var(--accent)] prose-blockquote:text-[var(--text-tertiary)] prose-hr:border-[var(--border-subtle)]">
      <slot />
    </div>

    <!-- Footer nav -->
    <footer class="mt-12 border-t border-[var(--border-subtle)] pt-8">
      <a
        href="/projects"
        class="text-sm text-[var(--accent)] transition-colors hover:text-[var(--accent-hover)]"
      >
        &larr; All Projects
      </a>
    </footer>
  </article>
</BaseLayout>
