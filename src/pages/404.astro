---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import { TOPIC_HUBS } from '../data/taxonomy';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist or has moved."
>
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-24 sm:py-32 text-center">
    <!-- Error code -->
    <p class="text-8xl font-bold tracking-tight text-[var(--text-disabled)] select-none mb-6" aria-hidden="true">
      404
    </p>

    <!-- Heading -->
    <h1 class="text-3xl font-bold tracking-tight text-[var(--text-primary)] sm:text-4xl mb-4">
      Page not found
    </h1>

    <!-- Description -->
    <p class="text-lg text-[var(--text-secondary)] leading-relaxed mb-10 max-w-md mx-auto">
      The URL you followed doesn't exist or the content has moved. It might have been renamed, deleted, or never existed.
    </p>

    <!-- Primary actions -->
    <div class="flex flex-wrap justify-center gap-4 mb-16">
      <Button href="/" variant="primary" size="lg">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Back to Home
      </Button>
      <Button href="/essays/" variant="secondary" size="lg">
        Browse Essays
      </Button>
    </div>

    <!-- Helpful links -->
    <div class="border-t border-[var(--border-subtle)] pt-10 text-left">
      <p class="text-sm font-semibold uppercase tracking-widest text-[var(--text-tertiary)] mb-5 text-center">
        Or try one of these
      </p>

      <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 sm:gap-3">
        {[
          { label: 'Essays', href: '/essays/' },
          { label: 'Series', href: '/series/' },
          { label: 'Projects', href: '/projects/' },
          { label: 'Tags', href: '/tags/' },
          { label: 'Portfolio', href: '/portfolio/' },
          { label: 'About', href: '/about/' },
        ].map(({ label, href }) => (
          <a
            href={href}
            class="rounded-lg border border-[var(--border-subtle)] bg-[var(--bg-surface)] px-4 py-3 text-sm font-medium text-[var(--text-secondary)] hover:border-[var(--accent)]/50 hover:text-[var(--accent)] transition-all text-center"
          >
            {label}
          </a>
        ))}
      </div>

      <!-- Topics -->
      <div class="mt-6">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--text-tertiary)] mb-3 text-center">
          Browse by topic
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          {TOPIC_HUBS.map((hub) => (
            <a
              href={`/topics/${hub.slug}/`}
              class="rounded-full border border-[var(--border-subtle)] px-3 py-1 text-xs text-[var(--text-tertiary)] hover:border-[var(--accent)]/50 hover:text-[var(--accent)] transition-colors"
            >
              {hub.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
