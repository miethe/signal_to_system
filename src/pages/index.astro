---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/cards/EssayCard.astro';
import ProjectCard from '../components/cards/ProjectCard.astro';
import SeriesCard from '../components/cards/SeriesCard.astro';
import Button from '../components/ui/Button.astro';
import InteractiveNetwork from '../components/interactive/InteractiveNetwork';
import { site } from '../data/site';
import { TOPIC_HUBS } from '../data/taxonomy';

// ---------------------------------------------------------------------------
// Data
// ---------------------------------------------------------------------------

const allPosts = await getCollection('posts');
const allProjects = await getCollection('projects');
const allSeries = await getCollection('series');

const publishedPosts = allPosts
  .filter((p) => p.data.status !== 'draft')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPosts = publishedPosts.filter((p) => p.data.featured).slice(0, 3);
const recentPosts = featuredPosts.length < 3
  ? publishedPosts.slice(0, 3)
  : featuredPosts;

const activeSeries = allSeries
  .filter((s) => s.data.status === 'active' || s.data.featured)
  .slice(0, 3);

const featuredProjects = allProjects.filter((p) => p.data.featured).slice(0, 3);

// Compute post count per series for SeriesCard
const seriesPostCounts = new Map<string, number>();
for (const post of publishedPosts) {
  if (post.data.series) {
    seriesPostCounts.set(post.data.series, (seriesPostCounts.get(post.data.series) ?? 0) + 1);
  }
}

// Topic hub icons (inline SVG paths keyed by slug)
const topicIcons: Record<string, string> = {
  'ai-agents': 'M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 8-8 8 8 0 0 1-8 8zm1-11v2h2v2h-2v2h-2v-2H9v-2h2V9z',
  'agentic-sdlc': 'M4 4h16v2H4zm0 4h10v2H4zm0 4h16v2H4zm0 4h10v2H4z',
  'technical-leadership': 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm14 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  'cto': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  'architecture': 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z',
  'platform-engineering': 'M20 7H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2zM12 15a2 2 0 1 1 0-4 2 2 0 0 1 0 4z',
  'projects': 'M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2zM14 2v6h6',
};

const topicColors: Record<string, string> = {
  'ai-agents': 'from-indigo-500/20 to-violet-500/10 border-indigo-500/30 hover:border-indigo-400/60',
  'agentic-sdlc': 'from-violet-500/20 to-purple-500/10 border-violet-500/30 hover:border-violet-400/60',
  'technical-leadership': 'from-sky-500/20 to-cyan-500/10 border-sky-500/30 hover:border-sky-400/60',
  'cto': 'from-amber-500/20 to-orange-500/10 border-amber-500/30 hover:border-amber-400/60',
  'architecture': 'from-emerald-500/20 to-teal-500/10 border-emerald-500/30 hover:border-emerald-400/60',
  'platform-engineering': 'from-rose-500/20 to-pink-500/10 border-rose-500/30 hover:border-rose-400/60',
  'projects': 'from-zinc-500/20 to-slate-500/10 border-zinc-500/30 hover:border-zinc-400/60',
};

const topicIconColors: Record<string, string> = {
  'ai-agents': 'text-indigo-400',
  'agentic-sdlc': 'text-violet-400',
  'technical-leadership': 'text-sky-400',
  'cto': 'text-amber-400',
  'architecture': 'text-emerald-400',
  'platform-engineering': 'text-rose-400',
  'projects': 'text-zinc-400',
};
---

<BaseLayout
  title={undefined}
  description={site.description}
>
  <!-- =========================================================
       HERO
       ========================================================= -->
  <section class="relative overflow-hidden bg-[var(--bg-base)]">
    <!-- Network visualization background -->
    <div class="absolute inset-0 z-0 opacity-60" aria-hidden="true">
      <InteractiveNetwork className="w-full h-full" client:idle />
    </div>

    <!-- Radial gradient overlay for readability -->
    <div class="absolute inset-0 z-10 bg-gradient-to-b from-[var(--bg-base)]/30 via-[var(--bg-base)]/70 to-[var(--bg-base)]" aria-hidden="true" />

    <!-- Content (hero is always light-on-dark regardless of theme) -->
    <div class="relative z-20 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pt-28 pb-24 sm:pt-40 sm:pb-36">
      <!-- Eyebrow -->
      <p class="font-mono mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--border-subtle)] bg-[var(--accent-subtle)] px-3 py-1 text-xs font-semibold uppercase tracking-widest text-[var(--accent-text)]">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--accent)] animate-pulse" aria-hidden="true" />
        Technical Publication
      </p>

      <h1 class="font-serif text-5xl font-bold tracking-tight text-[var(--text-primary)] sm:text-7xl lg:text-[5rem] mb-8 max-w-4xl leading-[1.05]">
        Signal to
        <span class="italic text-[var(--accent)]"> System</span>
      </h1>

      <p class="text-xl text-[var(--text-secondary)] max-w-2xl leading-relaxed mb-4">
        {site.subtitle}
      </p>
      <p class="text-base text-[var(--text-tertiary)] max-w-xl leading-relaxed mb-12">
        Long-form essays and practical frameworks for technical executives, architects, and builders navigating the agent-era shift in software delivery.
      </p>

      <div class="flex flex-wrap gap-4">
        <Button href="/essays/" variant="primary" size="lg">
          Read the Essays
        </Button>
        <Button href="/start-here/" variant="secondary" size="lg">
          Start Here
        </Button>
        <Button href="/rss.xml" variant="ghost" size="lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/>
          </svg>
          RSS Feed
        </Button>
      </div>
    </div>
  </section>

  <!-- =========================================================
       POSITIONING / SIGNAL STATEMENT
       ========================================================= -->
  <section class="animate-on-scroll bg-[var(--bg-base)] pb-8 pt-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16">
      <dl class="grid grid-cols-1 gap-8 sm:grid-cols-3">
        {[
          {
            label: 'Depth over volume',
            value: 'Long-form',
            desc: 'Essays that earn their word count. No hot takes, no summaries of summaries.',
          },
          {
            label: 'Real systems experience',
            value: 'Practitioner-first',
            desc: 'Written from the seat of someone who has shipped systems, led organizations, and built alongside AI.',
          },
          {
            label: 'Architecture through leadership',
            value: 'Full-stack thinking',
            desc: 'From agent context engineering to org design to platform strategy — the full technical executive stack.',
          },
        ].map(({ label, value, desc }) => (
          <div class="border border-[var(--border-subtle)] bg-[var(--bg-surface)] p-6 rounded-2xl shadow-sm transition-all hover:border-[var(--accent)] hover:shadow-ambient">
            <dt class="font-mono text-[11px] font-bold uppercase tracking-widest text-[var(--accent)] mb-2">{label}</dt>
            <dd class="text-2xl font-bold text-[var(--text-primary)] mb-2">{value}</dd>
            <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{desc}</p>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- =========================================================
       FEATURED SERIES
       ========================================================= -->
  {activeSeries.length > 0 && (
    <section class="animate-on-scroll bg-[var(--bg-subtle)] py-24">
      <div class="max-w-7xl mx-auto px-8 lg:px-12">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
          <div>
            <h2 class="text-4xl font-serif text-[var(--text-primary)] mb-4">Featured Series</h2>
            <div class="h-1 w-24 bg-[var(--accent)]"></div>
          </div>
          <a class="font-mono text-sm uppercase tracking-widest text-[var(--accent)] hover:text-[var(--text-primary)] transition-colors flex items-center gap-2" href="/series/">
            View All Series <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>
        
        <a href={`/series/${activeSeries[0].id}/`} class="block relative group overflow-hidden rounded-xl bg-[var(--bg-surface)] shadow-ambient border-none">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="p-10 sm:p-12 flex flex-col justify-center relative overflow-hidden">
              <div class="absolute top-0 left-0 w-1 h-full bg-[var(--accent)]"></div>
              <div class="font-mono text-xs tracking-tighter text-[var(--accent)] mb-4 uppercase">Volume 01 / Deep Dive</div>
              <h3 class="text-4xl sm:text-5xl font-serif text-[var(--text-primary)] mb-6 leading-tight group-hover:text-[var(--accent)] transition-colors">{activeSeries[0].data.title}</h3>
              <p class="text-[var(--text-secondary)] font-sans text-lg leading-relaxed mb-8">
                  {activeSeries[0].data.excerpt}
              </p>
              <div class="flex items-center gap-6">
                  <span class="text-sm font-mono text-[var(--text-tertiary)]">{seriesPostCounts.get(activeSeries[0].id) ?? 0} Part Series</span>
              </div>
            </div>
            
            <div class="relative min-h-[400px] bg-[var(--bg-base)] overflow-hidden">
                {activeSeries[0].data.heroImage ? (
                  <img src={activeSeries[0].data.heroImage} alt={activeSeries[0].data.title} class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700" />
                ) : (
                  <div class="absolute inset-0 opacity-20 bg-gradient-to-tr from-[var(--bg-base)] via-[var(--bg-subtle)] to-[var(--accent-muted)]">
                      <div class="h-full w-full bg-[linear-gradient(to_right,var(--bg-surface)_1px,transparent_1px),linear-gradient(to_bottom,var(--bg-surface)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-r from-[var(--bg-surface)] via-transparent to-transparent"></div>
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- =========================================================
       CORE CONTENT PILLARS
       ========================================================= -->
  <section class="animate-on-scroll py-24 bg-[var(--bg-base)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-12">
      <div class="mb-16">
        <h2 class="text-sm font-mono uppercase tracking-[0.3em] text-[var(--text-tertiary)] mb-2">The Architecture</h2>
        <h3 class="text-4xl font-serif text-[var(--text-primary)]">Core Content Pillars</h3>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {TOPIC_HUBS.slice(0, 3).map((hub, i) => (
          <a href={`/topics/${hub.slug}/`} class={`group p-8 rounded-xl transition-all flex flex-col justify-between border-none ${i === 0 ? 'md:col-span-2 lg:col-span-2 bg-[var(--bg-surface)] hover:bg-[var(--bg-subtle)] aspect-video md:aspect-auto' : 'bg-[var(--bg-subtle)] hover:bg-[var(--bg-surface)]'}`}>
            <div>
              <span class={`material-symbols-outlined text-4xl mb-6 ${topicIconColors[hub.slug] ?? 'text-[var(--accent)]'}`}>
                  {i === 0 ? 'smart_toy' : i === 1 ? 'groups' : 'architecture'}
              </span>
              <h4 class="text-2xl font-serif text-[var(--text-primary)] mb-4">{hub.label}</h4>
              <p class="text-[var(--text-secondary)] font-sans text-sm leading-relaxed">{hub.description}</p>
            </div>
            <div class={`mt-8 font-mono text-xs uppercase tracking-widest flex items-center gap-2 ${topicIconColors[hub.slug] ?? 'text-[var(--accent)]'}`}>
                Explore <span class="material-symbols-outlined text-xs">north_east</span>
            </div>
          </a>
        ))}
        
        <!-- Pillar 4 (Special Bottom) -->
        <div class="md:col-span-3 lg:col-span-4 p-8 rounded-xl bg-[var(--bg-base)] border border-[var(--border-subtle)] flex flex-col md:flex-row items-center justify-between gap-8 hover:border-[var(--accent)] transition-colors">
            <div class="flex items-center gap-6">
                <span class="material-symbols-outlined text-5xl text-[var(--text-tertiary)] opacity-50">terminal</span>
                <div>
                    <h4 class="text-2xl font-serif text-[var(--text-primary)] mb-1">Side Projects & Lab</h4>
                    <p class="text-[var(--text-secondary)] font-sans text-sm">Where theory meets the metal. Open source tools and experiments from the builder's desk.</p>
                </div>
            </div>
            <a href="/projects/" class="whitespace-nowrap px-6 py-3 bg-[var(--bg-surface)] text-[var(--text-primary)] font-mono text-xs uppercase tracking-widest rounded-md hover:bg-[var(--accent-subtle)] hover:text-[#000] focus:ring focus:ring-[var(--accent)] focus:outline-none transition-all">
                Browse the Lab
            </a>
        </div>
      </div>
    </div>
  </section>

  <!-- =========================================================
       LATEST ESSAYS
       ========================================================= -->
  <section class="animate-on-scroll py-24 bg-[var(--bg-surface)]">
    <div class="max-w-7xl mx-auto px-8 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <div class="lg:col-span-4">
                <div class="sticky top-32">
                    <h2 class="text-4xl sm:text-5xl font-serif text-[var(--text-primary)] mb-8">Latest <br/><span class="text-[var(--accent)] italic">Essays</span></h2>
                    <p class="text-[var(--text-secondary)] font-sans mb-8 leading-relaxed">
                        Regular transmissions on the intersection of management, engineering, and systems thinking.
                    </p>
                    <div class="flex flex-col gap-4">
                        <div class="flex items-center gap-3 text-[var(--text-tertiary)]">
                            <span class="w-1.5 h-1.5 rounded-full bg-[var(--accent)]"></span>
                            <span class="font-mono text-xs uppercase tracking-widest">Deep Dives & Frameworks</span>
                        </div>
                         <div class="flex items-center gap-3 text-[var(--text-tertiary)]">
                            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                            <span class="font-mono text-xs uppercase tracking-widest">Field Notes</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="lg:col-span-8">
                <div class="flex flex-col">
                    {publishedPosts.slice(0, 5).map((post, i) => (
                        <article class="group relative py-8 border-b border-[var(--border-subtle)] last:border-0 hover:bg-[var(--bg-subtle)] -mx-6 px-6 rounded-xl transition-colors">
                            <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-4 mb-4">
                                <div class="flex gap-4 items-center">
                                    <span class="font-mono text-[10px] text-[var(--text-tertiary)] uppercase tracking-tight">
                                        {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                                    </span>
                                    <div class="h-px w-8 bg-[var(--border-subtle)]"></div>
                                    <span class="px-2 py-0.5 rounded bg-[var(--accent-subtle)] text-[var(--accent)] text-[10px] font-mono uppercase tracking-widest">
                                        {post.data.category}
                                    </span>
                                </div>
                                <span class="font-mono text-[10px] text-[var(--text-tertiary)] uppercase tracking-widest">{post.data.readTime}</span>
                            </div>
                            <h3 class="text-3xl font-serif text-[var(--text-primary)] mb-4 group-hover:text-[var(--accent)] transition-colors">
                                <a href={`/essays/${post.id}/`} class="focus:outline-none">
                                    <span class="absolute inset-0" aria-hidden="true"></span>
                                    {post.data.title}
                                </a>
                            </h3>
                            <p class="text-[var(--text-secondary)] font-sans mb-6 max-w-2xl leading-relaxed">{post.data.excerpt}</p>
                            <span class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-[var(--text-primary)] group-hover:underline underline-offset-4 pointer-events-none">Read Full Transmission <span class="material-symbols-outlined text-sm">arrow_outward</span></span>
                        </article>
                    ))}
                </div>
            </div>
        </div>
    </div>
  </section>

  <!-- =========================================================
       FEATURED PROJECTS
       ========================================================= -->
  {featuredProjects.length > 0 && (
    <section class="bg-[var(--bg-subtle)]">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
        <div class="flex items-end justify-between mb-10">
          <div>
            <p class="font-mono text-xs font-bold uppercase tracking-widest text-[var(--accent)] mb-2">Builds & artifacts</p>
            <h2 class="font-serif text-4xl font-bold tracking-tight text-[var(--text-primary)]">Featured Projects</h2>
          </div>
          <a
            href="/projects/"
            class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors"
          >
            All projects
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {featuredProjects.map((p) => (
            <ProjectCard
              title={p.data.title}
              excerpt={p.data.excerpt}
              date={p.data.date}
              type={p.data.type}
              tags={p.data.tags}
              slug={p.id}
              featured={p.data.featured ?? false}
              visibility={p.data.visibility}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- =========================================================
       AUTHOR BIO
       ========================================================= -->
  <section class="animate-on-scroll bg-[var(--bg-base)]">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-20">
      <div class="rounded-3xl border border-[var(--border-subtle)] bg-[var(--bg-surface)] p-8 sm:p-12 lg:flex lg:items-center lg:gap-12 shadow-ambient">
        <!-- Avatar initials -->
        <div class="mb-8 lg:mb-0 lg:shrink-0">
          <div class="flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-indigo-500 to-violet-600 text-2xl font-bold text-white overflow-hidden">
            <img src="/assets/1M.png" alt={site.author.name} class="h-full w-full object-cover" />
          </div>
        </div>

        <!-- Bio -->
        <div class="flex-1">
          <p class="text-xs font-semibold uppercase tracking-widest text-[var(--text-tertiary)] mb-2">The author</p>
          <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-3">{site.author.name}</h2>
          <p class="text-[var(--text-secondary)] leading-relaxed mb-6 max-w-2xl">
            Technical executive and architect with deep experience across AI systems, platform engineering, and enterprise software delivery. Former Red Hat solutions architect. Writing at the intersection of agentic AI, system design, and the organizational challenges of building great software.
          </p>
          <div class="flex flex-wrap gap-3">
            <Button href="/about/" variant="secondary" size="sm">Full bio</Button>
            <a
              href={site.author.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm text-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors"
            >
              GitHub
            </a>
            <a
              href={site.author.social.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm text-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors"
            >
              LinkedIn
            </a>
            <a
              href={site.author.social.twitter}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm text-[var(--text-tertiary)] hover:text-[var(--text-primary)] transition-colors"
            >
              Twitter / X
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- IntersectionObserver for entrance animations -->
  <script>
    const animatedSections = document.querySelectorAll('.animate-on-scroll');
    if (animatedSections.length > 0 && !document.documentElement.classList.contains('perf-lite')) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      animatedSections.forEach((section) => observer.observe(section));
    } else {
      // Ensure content is visible if perf-lite or no observer support
      animatedSections.forEach((s) => {
        s.style.opacity = '1';
        s.style.transform = 'none';
      });
    }
  </script>
</BaseLayout>
