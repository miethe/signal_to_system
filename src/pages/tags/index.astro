---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { TAG_REGISTRY, tagsBySlug } from '../../data/taxonomy';
import { slugify } from '../../lib/utils';

// ---------------------------------------------------------------------------
// Build tag frequency map across posts + projects
// ---------------------------------------------------------------------------

const allPosts = await getCollection('posts');
const allProjects = await getCollection('projects');

const tagCounts = new Map<string, number>();

for (const post of allPosts) {
  if (post.data.status === 'draft') continue;
  for (const tag of post.data.tags ?? []) {
    const slug = slugify(tag);
    tagCounts.set(slug, (tagCounts.get(slug) ?? 0) + 1);
  }
}

for (const project of allProjects) {
  for (const tag of project.data.tags ?? []) {
    const slug = slugify(tag);
    tagCounts.set(slug, (tagCounts.get(slug) ?? 0) + 1);
  }
}

// Build sorted tag list — registry tags first (ordered), then any unregistered
const registrySet = new Set(TAG_REGISTRY.map((t) => t.slug));

const registeredTags = TAG_REGISTRY.filter((t) => tagCounts.has(t.slug))
  .map((t) => ({ slug: t.slug, label: t.label, description: t.description, count: tagCounts.get(t.slug)! }))
  .sort((a, b) => b.count - a.count);

const allTagSlugs = [...tagCounts.keys()];
const unregisteredTags = allTagSlugs
  .filter((s) => !registrySet.has(s))
  .map((s) => ({ slug: s, label: s.replace(/-/g, ' '), description: undefined, count: tagCounts.get(s)! }))
  .sort((a, b) => b.count - a.count);

const allTags = [...registeredTags, ...unregisteredTags];
const totalTagCount = allTags.length;
---

<BaseLayout
  title="Tags"
  description="Browse all tags across essays and projects on Signal to System."
>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <!-- Page header -->
    <header class="mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-10">
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl mb-4">
        Tags
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 leading-relaxed">
        {totalTagCount} tags across essays and projects. Each links to all content sharing that concept.
      </p>
    </header>

    {allTags.length === 0 ? (
      <div class="rounded-xl border border-dashed border-zinc-300 dark:border-zinc-700 p-16 text-center">
        <p class="text-zinc-500 dark:text-zinc-400">No tags found.</p>
      </div>
    ) : (
      <div class="space-y-10">
        <!-- Tag cloud — sized by frequency -->
        <section>
          <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6">
            All tags by frequency
          </h2>
          <div class="flex flex-wrap gap-2 items-baseline">
            {allTags.map(({ slug, label, count }) => {
              const maxCount = allTags[0]?.count ?? 1;
              const pct = count / maxCount;
              const sizeClass = pct > 0.75
                ? 'text-lg font-semibold'
                : pct > 0.5
                ? 'text-base font-medium'
                : pct > 0.25
                ? 'text-sm font-medium'
                : 'text-xs font-normal';

              return (
                <a
                  href={`/tags/${slug}/`}
                  class:list={[
                    'rounded-md border px-2.5 py-1 transition-all duration-150',
                    'border-zinc-200 bg-zinc-50 text-zinc-700 hover:border-indigo-300 hover:bg-indigo-50 hover:text-indigo-700',
                    'dark:border-zinc-700 dark:bg-zinc-800/60 dark:text-zinc-300 dark:hover:border-indigo-700 dark:hover:bg-indigo-900/30 dark:hover:text-indigo-300',
                    sizeClass,
                  ]}
                >
                  {label}
                  <sup class="ml-0.5 text-[10px] text-zinc-400 dark:text-zinc-500">{count}</sup>
                </a>
              );
            })}
          </div>
        </section>

        <!-- Registry tags with descriptions -->
        {registeredTags.length > 0 && (
          <section>
            <h2 class="text-xs font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6">
              Defined tags
            </h2>
            <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
              {registeredTags.map(({ slug, label, description, count }) => (
                <li>
                  <a
                    href={`/tags/${slug}/`}
                    class="group flex items-start gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 hover:border-indigo-300 dark:hover:border-indigo-700 transition-all duration-150"
                  >
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center justify-between gap-2 mb-0.5">
                        <span class="font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                          {label}
                        </span>
                        <span class="text-xs text-zinc-400 dark:text-zinc-500 shrink-0">
                          {count} {count === 1 ? 'item' : 'items'}
                        </span>
                      </div>
                      {description && (
                        <p class="text-xs text-zinc-500 dark:text-zinc-400 leading-relaxed">
                          {description}
                        </p>
                      )}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )}
      </div>
    )}
  </div>
</BaseLayout>
