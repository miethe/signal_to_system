---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayCard from '../../components/cards/EssayCard.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';
import { TAG_REGISTRY, tagsBySlug } from '../../data/taxonomy';
import { slugify } from '../../lib/utils';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const allProjects = await getCollection('projects');

  // Collect all unique tag slugs
  const tagSlugSet = new Set<string>();

  for (const post of allPosts) {
    if (post.data.status === 'draft') continue;
    for (const tag of post.data.tags ?? []) {
      tagSlugSet.add(slugify(tag));
    }
  }
  for (const project of allProjects) {
    for (const tag of project.data.tags ?? []) {
      tagSlugSet.add(slugify(tag));
    }
  }

  return [...tagSlugSet].map((tagSlug) => {
    const matchedPosts = allPosts.filter(
      (p) =>
        p.data.status !== 'draft' &&
        (p.data.tags ?? []).some((t) => slugify(t) === tagSlug),
    ).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    const matchedProjects = allProjects.filter((p) =>
      (p.data.tags ?? []).some((t) => slugify(t) === tagSlug),
    ).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { tag: tagSlug },
      props: { tagSlug, posts: matchedPosts, projects: matchedProjects },
    };
  });
}

const { tagSlug, posts, projects } = Astro.props;

// Look up registry definition
const tagDef = tagsBySlug[tagSlug];
const tagLabel = tagDef?.label ?? tagSlug.replace(/-/g, ' ');
const tagDescription = tagDef?.description;
const totalCount = posts.length + projects.length;
---

<BaseLayout
  title={`#${tagLabel}`}
  description={tagDescription ?? `All content tagged "${tagLabel}" on Signal to System.`}
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/tags/" class="hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">Tags</a>
      <span aria-hidden="true">/</span>
      <span class="text-zinc-900 dark:text-zinc-100">{tagLabel}</span>
    </nav>

    <!-- Page header -->
    <header class="mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-10">
      <div class="mb-3">
        <span class="inline-block rounded-md bg-indigo-100 dark:bg-indigo-900/40 px-2.5 py-1 text-xs font-medium text-indigo-700 dark:text-indigo-300">
          #{tagLabel}
        </span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl mb-4">
        {tagLabel}
      </h1>
      {tagDescription && (
        <p class="text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl leading-relaxed mb-2">
          {tagDescription}
        </p>
      )}
      <p class="text-zinc-500 dark:text-zinc-400">
        {totalCount} {totalCount === 1 ? 'item' : 'items'} — {posts.length} {posts.length === 1 ? 'essay' : 'essays'}, {projects.length} {projects.length === 1 ? 'project' : 'projects'}
      </p>
    </header>

    <div class="space-y-16">
      <!-- Essays -->
      {posts.length > 0 && (
        <section>
          <h2 class="text-sm font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6">
            Essays — {posts.length}
          </h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <EssayCard
                title={post.data.title}
                excerpt={post.data.excerpt}
                date={post.data.date}
                readTime={post.data.readTime}
                category={post.data.category}
                tags={post.data.tags}
                slug={post.id}
                contentType={post.data.contentType}
                featured={false}
              />
            ))}
          </div>
        </section>
      )}

      <!-- Projects -->
      {projects.length > 0 && (
        <section>
          <h2 class="text-sm font-semibold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 mb-6">
            Projects — {projects.length}
          </h2>
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {projects.map((project) => (
              <ProjectCard
                title={project.data.title}
                excerpt={project.data.excerpt}
                date={project.data.date}
                type={project.data.type}
                tags={project.data.tags}
                slug={project.id}
                featured={false}
                visibility={project.data.visibility}
              />
            ))}
          </div>
        </section>
      )}
    </div>

    <!-- Back link -->
    <div class="mt-12">
      <a
        href="/tags/"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5"/><path d="m12 19-7-7 7-7"/>
        </svg>
        All Tags
      </a>
    </div>
  </div>
</BaseLayout>
