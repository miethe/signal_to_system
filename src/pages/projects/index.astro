---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';

// ---------------------------------------------------------------------------
// Data
// ---------------------------------------------------------------------------

const allProjects = await getCollection('projects');

const projects = allProjects.sort((a, b) => {
  // Featured first, then by date
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

// Unique types for filter
const types = [...new Set(projects.map((p) => p.data.type))].sort();

// Count per type
const typeCounts = new Map<string, number>();
for (const p of projects) {
  typeCounts.set(p.data.type, (typeCounts.get(p.data.type) ?? 0) + 1);
}

const url = new URL(Astro.request.url);
const typeParam = url.searchParams.get('type') ?? '';

const filtered = typeParam
  ? projects.filter((p) => p.data.type.toLowerCase() === typeParam.toLowerCase())
  : projects;
---

<BaseLayout
  title="Projects"
  description="Builds, prototypes, frameworks, and artifacts — hands-on technical work alongside the writing."
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <!-- Page header -->
    <header class="mb-12 border-b border-[var(--border-subtle)] pb-10">
      <h1 class="font-serif text-4xl font-bold tracking-tight text-[var(--text-primary)] sm:text-5xl mb-4">
        Projects
      </h1>
      <p class="text-xl text-[var(--text-secondary)] max-w-2xl leading-relaxed">
        Hands-on builds and artifacts — the complement to the essays. Component libraries, frameworks, reference implementations, and architecture artifacts.
      </p>
    </header>

    <!-- Type filter -->
    {types.length > 1 && (
      <nav class="mb-10 flex flex-wrap gap-2" aria-label="Filter by type">
        <a
          href="/projects/"
          class:list={[
            'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium transition-colors',
            !typeParam
              ? 'bg-[var(--accent)] text-white dark:text-[var(--text-inverse)]'
              : 'bg-[var(--bg-muted)] text-[var(--text-secondary)] hover:bg-[var(--bg-subtle)] hover:text-[var(--text-primary)]',
          ]}
        >
          All
          <span class="text-xs opacity-70">({projects.length})</span>
        </a>
        {types.map((type) => {
          const count = typeCounts.get(type) ?? 0;
          const isActive = typeParam.toLowerCase() === type.toLowerCase();
          return (
            <a
              href={`/projects/?type=${encodeURIComponent(type)}`}
              class:list={[
                'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium transition-colors',
                isActive
                  ? 'bg-[var(--accent)] text-white dark:text-[var(--text-inverse)]'
                  : 'bg-[var(--bg-muted)] text-[var(--text-secondary)] hover:bg-[var(--bg-subtle)] hover:text-[var(--text-primary)]',
              ]}
            >
              {type}
              <span class="text-xs opacity-70">({count})</span>
            </a>
          );
        })}
      </nav>
    )}

    {projects.length === 0 ? (
      /* Entire collection is empty — "coming soon" state */
      <div class="rounded-2xl border border-dashed border-[var(--border)] p-16 sm:p-20 text-center">
        <span class="material-symbols-outlined text-5xl text-[var(--text-disabled)] mb-4 block">construction</span>
        <h2 class="text-2xl font-serif font-bold text-[var(--text-primary)] mb-3">Projects Coming Soon</h2>
        <p class="text-[var(--text-secondary)] max-w-md mx-auto leading-relaxed mb-6">
          Hands-on builds and artifacts are in the works. In the meantime, check out the portfolio for a summary of past and active work.
        </p>
        <a href="/portfolio/" class="inline-flex items-center gap-2 text-sm font-medium text-[var(--accent)] hover:text-[var(--accent-hover)] transition-colors">
          View Portfolio
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    ) : filtered.length === 0 ? (
      /* Filter returned no results */
      <div class="rounded-xl border border-dashed border-[var(--border)] p-16 text-center">
        <p class="text-[var(--text-secondary)] text-lg">No projects found{typeParam ? ` for type "${typeParam}"` : ''}.</p>
        <a href="/projects/" class="mt-4 inline-block text-sm text-[var(--accent)] hover:text-[var(--accent-hover)] hover:underline">Clear filter</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {filtered.map((project) => (
          <ProjectCard
            title={project.data.title}
            excerpt={project.data.excerpt}
            date={project.data.date}
            type={project.data.type}
            tags={project.data.tags}
            slug={project.id}
            featured={project.data.featured ?? false}
            visibility={project.data.visibility}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
