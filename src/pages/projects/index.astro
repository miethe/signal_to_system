---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';

// ---------------------------------------------------------------------------
// Data
// ---------------------------------------------------------------------------

const allProjects = await getCollection('projects');

const projects = allProjects.sort((a, b) => {
  // Featured first, then by date
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

// Unique types for filter
const types = [...new Set(projects.map((p) => p.data.type))].sort();

// Count per type
const typeCounts = new Map<string, number>();
for (const p of projects) {
  typeCounts.set(p.data.type, (typeCounts.get(p.data.type) ?? 0) + 1);
}

const url = new URL(Astro.request.url);
const typeParam = url.searchParams.get('type') ?? '';

const filtered = typeParam
  ? projects.filter((p) => p.data.type.toLowerCase() === typeParam.toLowerCase())
  : projects;
---

<BaseLayout
  title="Projects"
  description="Builds, prototypes, frameworks, and artifacts — hands-on technical work alongside the writing."
>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
    <!-- Page header -->
    <header class="mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-10">
      <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-5xl mb-4">
        Projects
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl leading-relaxed">
        Hands-on builds and artifacts — the complement to the essays. Component libraries, frameworks, reference implementations, and architecture artifacts.
      </p>
    </header>

    <!-- Type filter -->
    {types.length > 1 && (
      <nav class="mb-10 flex flex-wrap gap-2" aria-label="Filter by type">
        <a
          href="/projects/"
          class:list={[
            'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium transition-colors',
            !typeParam
              ? 'bg-sky-600 text-white dark:bg-sky-500'
              : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700',
          ]}
        >
          All
          <span class="text-xs opacity-70">({projects.length})</span>
        </a>
        {types.map((type) => {
          const count = typeCounts.get(type) ?? 0;
          const isActive = typeParam.toLowerCase() === type.toLowerCase();
          return (
            <a
              href={`/projects/?type=${encodeURIComponent(type)}`}
              class:list={[
                'inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium transition-colors',
                isActive
                  ? 'bg-sky-600 text-white dark:bg-sky-500'
                  : 'bg-zinc-100 text-zinc-700 hover:bg-zinc-200 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700',
              ]}
            >
              {type}
              <span class="text-xs opacity-70">({count})</span>
            </a>
          );
        })}
      </nav>
    )}

    {filtered.length === 0 ? (
      <div class="rounded-xl border border-dashed border-zinc-300 dark:border-zinc-700 p-16 text-center">
        <p class="text-zinc-500 dark:text-zinc-400 text-lg">No projects found{typeParam ? ` for type "${typeParam}"` : ''}.</p>
        <a href="/projects/" class="mt-4 inline-block text-sm text-sky-600 dark:text-sky-400 hover:underline">Clear filter</a>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {filtered.map((project) => (
          <ProjectCard
            title={project.data.title}
            excerpt={project.data.excerpt}
            date={project.data.date}
            type={project.data.type}
            tags={project.data.tags}
            slug={project.id}
            featured={project.data.featured ?? false}
            visibility={project.data.visibility}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
